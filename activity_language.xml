<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- APP ICON -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐄"
            android:textSize="70sp"
            android:layout_marginTop="40dp"/>

        <!-- APP TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grama-Vaxi"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#5E548E"
            android:layout_marginTop="10dp"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Village Animal Healthcare System"
            android:textSize="18sp"
            android:textColor="#7A6EA8"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

        <!-- INSTRUCTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Preferred Language"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="25dp"/>

        <!-- ENGLISH BUTTON -->
        <Button
            android:id="@+id/btnEnglish"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="English"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#8E7CC3"
            android:textColor="#FFFFFF"/>

        <!-- KANNADA BUTTON -->
        <Button
            android:id="@+id/btnKannada"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="ಕನ್ನಡ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#A48AD4"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protecting Livestock • Supporting Farmers"
            android:textSize="16sp"
            android:textStyle="italic"
            android:textColor="#6D6875"
            android:layout_marginTop="60dp"
            android:gravity="center"/>

    </LinearLayout>

</ScrollView>