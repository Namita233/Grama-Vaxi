<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- ICON -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📘"
            android:textSize="70sp"
            android:layout_marginTop="30dp"/>

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvTutorialTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to Use App"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#5E548E"
            android:layout_marginTop="15dp"/>

        <!-- STEPS -->
        <TextView
            android:id="@+id/tvTutorialSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Select language\n\n2. Register or Login\n\n3. Add animal details\n\n4. Upload animal image\n\n5. Enter vaccination date\n\n6. Receive reminder notifications\n\n7. Report sick animal"
            android:textSize="20sp"
            android:textColor="#000000"
            android:background="#EEE8FF"
            android:padding="24dp"
            android:layout_marginTop="40dp"/>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Helping Farmers Through Smart Healthcare"
            android:textSize="16sp"
            android:textStyle="italic"
            android:textColor="#6D6875"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>