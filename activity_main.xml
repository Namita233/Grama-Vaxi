<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grama-Vaxi"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#5E548E"
            android:layout_marginBottom="25dp"/>

        <!-- REGISTER BUTTON -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Register Animal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#8E7CC3"
            android:textColor="#FFFFFF"/>

        <!-- VIEW BUTTON -->
        <Button
            android:id="@+id/btnView"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="View Animals"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#8E7CC3"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <!-- HEALTHCARE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Healthcare Alerts"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4A4A4A"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="15dp"/>

        <!-- ALERT BOX -->
        <TextView
            android:id="@+id/tvAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Vaccination Awareness Alert\n\n• Vaccinate cattle every 6 months\n\n• Monitor animal health regularly\n\n• Report sick animals immediately"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#5C4B00"
            android:background="#FFF4CC"
            android:padding="18dp"/>

        <!-- REPORT BUTTON -->
        <Button
            android:id="@+id/btnDisease"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Report Sick Animal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#8E7CC3"
            android:textColor="#FFFFFF"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</ScrollView>