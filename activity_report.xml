<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvReportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Sick Animal"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#5E548E"
            android:layout_marginBottom="25dp"/>

        <!-- ANIMAL NAME -->
        <EditText
            android:id="@+id/etAnimalName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Animal Name"
            android:padding="15dp"/>

        <!-- SYMPTOMS -->
        <EditText
            android:id="@+id/etSymptoms"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Symptoms"
            android:padding="15dp"
            android:layout_marginTop="18dp"/>

        <!-- VILLAGE -->
        <EditText
            android:id="@+id/etVillage"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Village Name"
            android:padding="15dp"
            android:layout_marginTop="18dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Send Vet Alert"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#8E7CC3"
            android:textColor="#FFFFFF"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</ScrollView>